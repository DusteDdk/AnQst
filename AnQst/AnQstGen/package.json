{
  "name": "@dusted/anqst",
  "version": "1.5.0",
  "description": "Opinionated backend generator for webapps.",
  "keywords": [
    "nodejs",
    "qt",
    "angular",
    "webapp"
  ],
  "homepage": "https://github.com/DusteDdk/AnQst#readme",
  "bugs": {
    "url": "https://github.com/DusteDdk/AnQst/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DusteDdk/AnQst.git",
    "directory": "AnQstGen"
  },
  "license": "WTFPL",
  "author": "DusteD",
  "type": "commonjs",
  "main": "dist/src/app.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./dist/src/app.js"
    }
  },
  "bin": {
    "anqst": "dist/src/bin/anqst.js"
  },
  "files": [
    "dist/src",
    "index.d.ts",
    "spec/AnQst-Spec-DSL.d.ts",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "chmod:bin": "node -e \"require('node:fs').chmodSync('dist/src/bin/anqst.js', 0o755)\"",
    "build": "node scripts/build-with-stamp.js",
    "build:test": "npm run clean && tsc -p tsconfig.json && npm run chmod:bin",
    "prepare": "npm run build",
    "test": "npm run build:test && node --test dist/test/*.test.js",
    "start": "node dist/src/bin/anqst.js"
  },
  "dependencies": {
    "pngjs": "^7.0.0",
    "typescript": "^5.9.2"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/pngjs": "^6.0.5"
  }
}
