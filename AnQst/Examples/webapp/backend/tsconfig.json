{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "dist",
    "rootDir": "..",
    "baseUrl": ".",
    "paths": {
      "express": ["node_modules/@types/express/index.d.ts"],
      "ws": ["node_modules/@types/ws/index.d.ts"]
    },
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "src/**/*.ts",
    "../frontend/AnQst/generated/backend/node/express/UserManagement_anQst/index.ts"
  ]
}
