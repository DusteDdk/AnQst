{
  "name": "vanilla-ts-widget",
  "version": "0.0.0",
  "scripts": {
    "anqst:generate": "npx anqst generate ./AnQst/VanillaTsWidget.AnQst.d.ts",
    "frontend:build": "npm run anqst:generate && node build-frontend.mjs",
    "build": "npm run frontend:build && npx anqst build",
    "typecheck": "npm run anqst:generate && tsc --noEmit -p tsconfig.json",
    "watch": "npm run anqst:generate && node build-frontend.mjs --watch"
  },
  "private": true,
  "packageManager": "npm@10.9.2",
  "devDependencies": {
    "@dusted/anqst": "file:../../../../../AnQstGen",
    "esbuild": "^0.25.9",
    "typescript": "~5.9.2"
  },
  "AnQst": "./AnQst/VanillaTsWidget.settings.json"
}
