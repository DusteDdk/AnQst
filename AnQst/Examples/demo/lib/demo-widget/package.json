{
  "name": "demo-widget",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "anqst": "npx anqst",
    "anqst:test": "npx anqst test",
    "anqst:build": "npx anqst build",
    "build": "npx anqst build && npm run anqst:build",
    "watch": "ng build --watch --configuration development",
    "test": "npx anqst test && npm run anqst:test && ng test --watch=false"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@10.9.2",
  "dependencies": {
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.1.0",
    "@angular/platform-browser": "^21.1.0",
    "@angular/router": "^21.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.1.4",
    "@angular/cli": "^21.1.4",
    "@angular/compiler-cli": "^21.1.0",
    "anqst": "file:../../../../AnQstGen",
    "jsdom": "^27.1.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  },
  "AnQst": {
    "spec": "DemoHostWidget.AnQst.d.ts",
    "generate": [
      "QWidget",
      "AngularService",
      "//DOM",
      "//node_express_ws"
    ]
  }
}
